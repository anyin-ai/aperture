# Keep dev cruft and local data out of the backend image build context.
__pycache__
*.py[cod]
.venv
venv
env
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
# Local SQLite databases must never be baked into the image.
*.db
*.sqlite
*.sqlite3
tests
.git
.gitignore
Dockerfile
.dockerignore
.DS_Store
.env
.env.*
